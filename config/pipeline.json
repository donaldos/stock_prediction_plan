{
  "version": "1.3",
  "last_updated": "2026-03-07",
  "description": "파이프라인 단계별 전략 설정. CLI 인자가 있으면 여기 값을 override한다.",

  "loading": {
    "pdf_engine": "pdfplumber",
    "_pdf_engine_options": "pdfplumber | pymupdf | pdfminer | pypdf2 | auto"
  },

  "chunking": {
    "strategy": "recursive",
    "_strategy_options": "recursive | sentence | token | fixed",
    "params": {
      "fixed":     { "chunk_size": 500, "overlap": 50 },
      "recursive": { "chunk_size": 500, "overlap": 50 },
      "sentence":  { "sentences_per_chunk": 5, "overlap": 1 },
      "token":     { "chunk_tokens": 256, "overlap": 32 }
    }
  },

  "embedding": {
    "strategy": "bge",
    "_strategy_options": "bge | upstage | openai",
    "_note": "max_concurrent: upstage/openai 전략의 동시 배치 요청 수. API rate limit 고려해 조정",
    "params": {
      "bge":     { "batch_size": 32 },
      "upstage": { "batch_size": 50,  "max_concurrent": 4 },
      "openai":  { "batch_size": 512, "max_concurrent": 8 }
    }
  },

  "llm": {
    "strategy": "openai",
    "_strategy_options": "claude | openai | gemini",
    "_note": "RAG 예측 LLM. claude=claude-sonnet-4-6 (기본), openai=gpt-4o, gemini=gemini-2.0-flash",
    "ticker": "005930",
    "_ticker_note": "예측 대상 종목코드 (메인 종목)",
    "params": {
      "claude": {
        "model":       "claude-sonnet-4-6",
        "max_tokens":  1024,
        "temperature": 0.0
      },
      "openai": {
        "model":       "gpt-4o",
        "max_tokens":  1024,
        "temperature": 0.0
      },
      "gemini": {
        "model":       "gemini-2.0-flash",
        "max_tokens":  1024,
        "temperature": 0.0
      }
    }
  },

  "vectordb": {
    "strategy": "chroma",
    "_strategy_options": "chroma | pinecone",
    "collection": "stock_rag",
    "_collection_note": "Chroma=컬렉션명, Pinecone=네임스페이스명. 종목별 분리 시 ticker 코드 사용",
    "search": {
      "top_k": 5,
      "top_k_expanded": 10,
      "_top_k_expanded_note": "RAG 재시도 시 검색 범위 확장용"
    },
    "params": {
      "chroma":   { "persist_dir": "chroma_db" },
      "pinecone": { "index_name": "stock-rag", "max_concurrent": 4 }
    }
  }
}
