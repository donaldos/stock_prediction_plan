{
  "version": "1.1",
  "last_updated": "2026-03-06",
  "description": "데이터 수집 항목 및 소스 관리 파일",

  "sources": [
    {
      "id": "krx_ohlcv",
      "label": "국내 주가 OHLCV",
      "type": "price",
      "library": "FinanceDataReader",
      "fallback_library": "pykrx",
      "market": "KRX",
      "schedule": "daily_2x",
      "params": {
        "lookback_days": 30
      },
      "active": true
    },
    {
      "id": "krx_investor",
      "label": "투자자별 순매수 동향",
      "type": "investor_flow",
      "library": "pykrx",
      "market": "KRX",
      "schedule": "daily_2x",
      "params": {
        "lookback_days": 7,
        "note": "개인/기관합계/외국인합계/기타법인 순매수 일별 추이 + 주간 합계"
      },
      "active": true
    },
    {
      "id": "dart_disclosure",
      "label": "기업 공시",
      "type": "disclosure",
      "library": "DART_API",
      "market": "KRX",
      "schedule": "daily_2x",
      "params": {
        "lookback_days": 7,
        "report_types": ["A001", "A002", "F001"],
        "note": "A001=사업보고서, A002=반기보고서, F001=주요사항보고"
      },
      "active": true
    },
    {
      "id": "naver_news",
      "label": "뉴스",
      "type": "news",
      "library": "BeautifulSoup",
      "market": "KRX",
      "schedule": "daily_2x",
      "params": {
        "base_url": "https://finance.naver.com/item/news.nhn",
        "max_articles": 20,
        "note": "HTML 셀렉터 확인 필요 (TBD)"
      },
      "active": true
    },
    {
      "id": "dart_financial",
      "label": "재무제표",
      "type": "financial",
      "library": "DART_API",
      "market": "KRX",
      "schedule": "quarterly",
      "params": {
        "fs_div": "CFS",
        "note": "CFS=연결재무제표, OFS=별도재무제표"
      },
      "active": true
    },
    {
      "id": "us_price",
      "label": "미국 반도체 주가",
      "type": "price",
      "library": "yfinance",
      "market": "NASDAQ",
      "schedule": "daily_1x",
      "params": {
        "period": "2d",
        "note": "전일 종가 기준, tickers.json us_reference 참조"
      },
      "active": true
    },
    {
      "id": "sox_index",
      "label": "SOX 지수",
      "type": "index",
      "library": "yfinance",
      "market": "INDEX",
      "schedule": "daily_1x",
      "params": {
        "ticker": "^SOX",
        "period": "2d",
        "note": "등락률 계산 후 LangGraph Case 분기 기준값으로 활용"
      },
      "active": true
    },
    {
      "id": "pdf_files",
      "label": "PDF 리포트",
      "type": "pdf",
      "library": "pathlib",
      "market": "ALL",
      "schedule": "daily_2x",
      "params": {
        "directory": "collected_datas/pdf_datas",
        "note": "프로젝트 루트 기준 상대경로. PDF 파일 목록만 수집 (본문 추출은 data_loading 단계에서)"
      },
      "active": true
    }
  ],

  "schedule_definitions": {
    "daily_2x": "오전 8~9시 + 오후 4~5시 실행",
    "daily_1x": "오전 8~9시 1회 실행 (미국 전일 종가)",
    "quarterly": "분기 결산 공시 이후 1회 실행"
  },

  "retry_policy": {
    "max_retries": 3,
    "interval_seconds": 30,
    "on_final_failure": "use_previous_day_data",
    "on_no_fallback": "slack_alert_and_skip"
  }
}
