# API 키 설정 예시 파일.
# 이 파일을 복사해 .env 로 저장한 뒤 실제 값을 입력하세요.
# .env 는 절대 git에 커밋하지 마세요.

# DART OpenAPI 키 (https://opendart.fss.or.kr 에서 발급)
DART_API_KEY=your_dart_api_key_here

# 임베딩 API 키 (Phase 3에서 사용)
# Upstage Solar Embedding (https://console.upstage.ai 에서 발급)
UPSTAGE_API_KEY=your_upstage_api_key_here

# OpenAI Embedding (https://platform.openai.com 에서 발급)
OPENAI_API_KEY=your_openai_api_key_here

# LLM API 키 (Phase 5에서 사용) — 선택한 strategy에 해당하는 키만 필요
# Anthropic Claude (https://console.anthropic.com 에서 발급) — strategy="claude"
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini (https://aistudio.google.com 에서 발급) — strategy="gemini"
GOOGLE_API_KEY=your_google_api_key_here

# 벡터DB API 키 (Phase 4에서 사용)
# Pinecone (https://app.pinecone.io 에서 발급) — chroma 전략 사용 시 불필요
PINECONE_API_KEY=your_pinecone_api_key_here

# Slack Webhook URL (Phase 5에서 사용)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
